{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth0": {
    "Domain": "YOUR_AUTH0_DOMAIN",
    "Audience": "YOUR_AUTH0_AUDIENCE"
  },
  "ReverseProxy": {
    "Routes": {
      "market-route": {
        "ClusterId": "market-cluster",
        "Match": {
          "Path": "/api/market/{**remainder}"
        }
      }
    },
    "Clusters": {
      "market-cluster": {
        "Destinations": {
          "market-destination": {
            "Address": "http://localhost:8000"
          }
        }
      }
    }
  }
}